# ============================================================================
# CONFIGURAÇÃO SUPABASE - Variáveis de Ambiente
# ============================================================================
# INSTRUÇÕES:
# 1. Copie este arquivo para .env (copie o conteúdo exato)
# 2. Preencha com suas credenciais reais do Supabase
# 3. Nunca faça commit do arquivo .env em repositórios públicos
# 
# COMO OBTER AS CREDENCIAIS:
# 1. Acesse https://supabase.com
# 2. Faça login em sua conta
# 3. Selecione o projeto
# 4. Vá em "Settings" > "API"
# 5. Copie:
#    - Project URL → VITE_SUPABASE_URL
#    - Anon key (under "Project API keys") → VITE_SUPABASE_ANON_KEY
# ============================================================================

VITE_SUPABASE_URL=sua_url_do_supabase
VITE_SUPABASE_ANON_KEY=sua_chave_anon_do_supabase